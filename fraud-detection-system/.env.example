# Grafana Credentials
GRAFANA_ADMIN_USER=XXXXXXX
GRAFANA_ADMIN_PASSWORD=change-me-to-secure-password

# Alertmanager Email Configuration
ALERTMANAGER_EMAIL=your-email@example.com
ALERTMANAGER_EMAIL_PASSWORD=your-app-password

# Database credentials (for future use)
POSTGRES_USER=fraud_user
POSTGRES_PASSWORD=change-me-to-secure-password

# Instructions:
# 1. Copy this file to .env
# 2. Replace all placeholder values with actual credentials
# 3. Never commit the .env file to Git